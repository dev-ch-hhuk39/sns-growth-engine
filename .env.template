# v2 SNS統合スプレッドシートシステム 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.template .env

# ============================================================
# 必須：統合スプレッドシートID
# NOTE_MASTER_SHEET_ID は旧名称。SNS_MASTER_SHEET_ID に移行済み。
# ============================================================
SNS_MASTER_SHEET_ID=
# NOTE_MASTER_SHEET_ID=  # 旧名称（後方互換のため fallback として残す）

# ============================================================
# GCP サービスアカウント認証（どちらか一方を設定）
# SA_JSON_BASE64: base64エンコードしたサービスアカウントJSON（ライバー・夜職threads方式）
# GCP_SA_JSON: JSONをそのまま貼った文字列（夜職x方式）
# ============================================================
SA_JSON_BASE64=
GCP_SA_JSON=

# ============================================================
# Gemini API
# GEMINI_MODEL_CANDIDATES: カンマ区切りで優先順に指定
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash-lite@v1beta,gemini-2.5-flash@v1beta,gemini-2.5-pro@v1beta
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# 動作モード（安全ガード）
# DRY_RUN=true    : シート書き込み & LLM 両方モック
# MOCK_LLM=true   : LLM のみモック（シート書き込みは行う）
# MOCK_SHEETS=true: Sheets を MockSheetsClient に強制切替
# PUBLISH_ENABLED : Phase 3-D の X 手動投稿テストまで false のまま
# ALLOW_REAL_X_POST     : Phase 3-D で1件手動投稿テスト時のみ true にする
# ALLOW_REAL_THREADS_POST: Phase 3-E で1件手動投稿テスト時のみ true にする
# ============================================================
DRY_RUN=false
MOCK_LLM=false
MOCK_SHEETS=false
PUBLISH_ENABLED=false
ALLOW_REAL_X_POST=false
ALLOW_REAL_THREADS_POST=false

# ============================================================
# X（旧 Twitter）API 認証情報
# OAuth 1.0a 方式（ユーザーとして投稿する場合に使用）
#   X_API_KEY + X_API_SECRET: アプリの Consumer Keys
#   X_ACCESS_TOKEN + X_ACCESS_TOKEN_SECRET: アカウントの Access Token
# OAuth 2.0 方式（PKCE / Client Credentials）
#   X_CLIENT_ID + X_CLIENT_SECRET: OAuth 2.0 Client Credentials
#   X_OAUTH2_ACCESS_TOKEN: 発行済みアクセストークン
#   X_OAUTH2_REFRESH_TOKEN: リフレッシュトークン（長期運用時）
#   X_REDIRECT_URI: OAuth 2.0 認証コールバック URI
# X_BEARER_TOKEN: 読み取り専用 Bearer Token（投稿には OAuth 1.0a を使用）
# ============================================================
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# ============================================================
# Threads API 認証情報
# Meta Developer App から取得（Threads API）
#   THREADS_ACCESS_TOKEN: ユーザーアクセストークン（長期トークン推奨）
#   THREADS_USER_ID: Threads ユーザー ID（数値 ID）
#   THREADS_APP_ID: Meta App ID
#   THREADS_APP_SECRET: Meta App Secret
#   THREADS_API_VERSION: API バージョン（デフォルト: v1.0）
# ============================================================
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_API_VERSION=v1.0

# ============================================================
# 任意：Discord 通知
# ============================================================
DISCORD_WEBHOOK_URL=
