{
  "media_growth_engine_enabled": true,
  "production_autopilot_enabled": true,
  "target_account_id": "liver_manager",
  "allowed_target_account_ids": ["liver_manager", "night_scout"],
  "allowed_rights_statuses": ["owned", "licensed", "approved_creator_clip"],
  "blocked_rights_statuses": ["third_party_reference_only", "reference_only", "unknown", "restricted", "not_allowed"],
  "allowed_source_ids": [
    "src_lm_yt_user_001",
    "src_lm_tt_user_001",
    "src_lm_tt_user_002",
    "src_lm_tt_user_003",
    "src_ns_yt_cand_001",
    "src_ns_yt_cand_002",
    "src_ns_yt_cand_003",
    "src_ns_yt_cand_004",
    "src_ns_yt_cand_005",
    "src_ns_yt_cand_006",
    "src_ns_yt_cand_007",
    "src_ns_yt_cand_008",
    "src_ns_yt_cand_009"
  ],
  "download_enabled": true,
  "transcription_enabled": true,
  "clip_candidate_generation_enabled": true,
  "cut_enabled": true,
  "upload_enabled": true,
  "video_post_enabled": true,
  "require_permission_evidence": true,
  "require_clip_review_before_cut": false,
  "require_media_validator_before_post": true,
  "max_clips_per_source_per_run": 3,
  "target_aspect_ratio": "9:16",
  "clip_duration_min_seconds": 8,
  "clip_duration_max_seconds": 45,
  "subtitle_enabled": false,
  "subtitle_policy": "disabled_by_user",
  "cloudinary_upload_enabled": true,
  "threads_video_post_enabled": true,
  "source_video_discovery_enabled": true,
  "source_video_discovery_apply_enabled": true,
  "require_source_media_autopilot_enabled": true,
  "media_schedule_enabled": true,
  "media_public_post_auto_enabled": true,
  "auto_approve_clip_candidates": true,
  "min_auto_clip_score": 80,
  "media_daily_post_cap": 2,
  "media_prepare_before_post_minutes": 120,
  "saved_media_post_enabled": true,
  "saved_media_post_requires_uploaded_unused_asset": true,
  "saved_media_post_fallback": "text_only_fallback",
  "direct_reference_media_enabled": true,
  "asset_inventory_targets": {
    "night_scout": {"direct_reference_media": 3, "generated_clip_media": 3},
    "liver_manager": {"direct_reference_media": 3, "generated_clip_media": 3}
  },
  "auto_save_discovered_videos": true,
  "auto_save_clip_candidates": true,
  "allowed_source_types_for_discovery": ["channel", "account"],
  "max_videos_per_source_scan": 12,
  "max_new_videos_per_source_per_run": 3,
  "max_total_new_videos_per_run": 12,
  "skip_already_seen_videos": true,
  "skip_already_clipped_videos": false,
  "allow_multiple_clips_per_video": true,
  "max_clip_candidates_per_video": 3,
  "min_clip_candidates_per_video": 1,
  "clip_overlap_policy": "block_overlapping_ranges",
  "clip_overlap_tolerance_seconds": 2,
  "dedupe_keys": [
    "platform",
    "source_id",
    "video_id",
    "canonical_video_url"
  ],
  "video_status_flow": [
    "DISCOVERED",
    "TRANSCRIPT_PLANNED",
    "ANALYZED",
    "CLIP_CANDIDATES_READY",
    "DOWNLOADED",
    "CUT",
    "UPLOADED",
    "POSTED",
    "SKIPPED",
    "BLOCKED"
  ],
  "discovery_default_status": "DISCOVERED",
  "dry_run_default": true
}
